{
  "common_keys": ["NONEBOT_ADAPTERS", "NONEBOT_HOST", "NONEBOT_PORT", "WHITELIST_FILE"],
  "channels": [
    {
      "id": "telegram",
      "label": "Telegram",
      "kind": "nonebot",
      "adapter": "telegram",
      "env_key": "TELEGRAM_BOTS",
      "emoji": "📱",
      "help": "Telegram 使用 BotFather 创建 bot 后填入 token。保存后会自动把 telegram 加入 NONEBOT_ADAPTERS；重启后生效。",
      "setup_instructions": [
        "1. Open Telegram and message @BotFather",
        "2. Send /newbot, name the bot, copy the token",
        "3. Use Telegram numeric user ID in the whitelist"
      ],
      "fields": [
        {
          "name": "token",
          "label": "Bot token",
          "target": "bot",
          "type": "password",
          "required": true,
          "placeholder": "123456789:AAExample_BotFatherToken",
          "help": "BotFather 给出的 token，格式通常是数字 bot id、冒号、较长的 secret。",
          "pattern": "^[0-9]{6,}:[A-Za-z0-9_-]{20,}$",
          "invalid_message": "Telegram Bot token 格式不对；请粘贴 @BotFather 给出的完整 token，例如 123456789:AA..."
        },
        {
          "name": "name",
          "label": "Local bot label",
          "target": "bot",
          "type": "text",
          "default": "bot1",
          "placeholder": "bot1",
          "help": "本地备注名，可留默认。"
        }
      ]
    },
    {
      "id": "qq",
      "label": "QQ",
      "kind": "nonebot",
      "adapter": "qq",
      "env_key": "QQ_BOTS",
      "emoji": "🐧",
      "help": "QQ 官方机器人需要 app id、bot secret 和 intents。沙箱测试时把 QQ_IS_SANDBOX 设为 true；生产环境设为 false。",
      "setup_instructions": [
        "1. https://q.qq.com -> register a QQ bot",
        "2. Copy AppID and AppSecret",
        "3. Choose public_messages and/or direct_message intents"
      ],
      "fields": [
        {
          "name": "id",
          "label": "App ID",
          "target": "bot",
          "type": "text",
          "required": true,
          "placeholder": "qq_app_id",
          "help": "QQ 开放平台应用 ID。"
        },
        {
          "name": "secret",
          "label": "Bot secret",
          "target": "bot",
          "type": "password",
          "required": true,
          "placeholder": "qq_bot_secret",
          "help": "QQ bot secret。"
        },
        {
          "name": "public_messages",
          "label": "Enable group messages",
          "target": "bot_intents",
          "type": "boolean",
          "default": "true",
          "help": "写入 intents.public_messages。"
        },
        {
          "name": "direct_message",
          "label": "Enable direct messages",
          "target": "bot_intents",
          "type": "boolean",
          "default": "true",
          "help": "写入 intents.direct_message。"
        },
        {
          "name": "QQ_IS_SANDBOX",
          "label": "Use QQ sandbox",
          "target": "env",
          "type": "boolean",
          "env_key": "QQ_IS_SANDBOX",
          "default": "false",
          "help": "沙箱环境填 true，正式环境填 false。"
        }
      ]
    },
    {
      "id": "onebotv11",
      "label": "OneBot V11",
      "kind": "nonebot",
      "adapter": "onebot.v11",
      "env_key": "ONEBOTV11_BOTS",
      "emoji": "🤖",
      "help": "OneBot V11 通常连接 NapCat、Lagrange、go-cqhttp 等实现。按你的 OneBot 实现填写连接字段。",
      "setup_instructions": [
        "1. Stand up a OneBot V11 implementation",
        "2. Configure reverse WebSocket or HTTP according to the adapter docs",
        "3. Keep access_token consistent on both sides if used"
      ],
      "fields": [
        {
          "name": "host",
          "label": "Host",
          "target": "bot",
          "type": "text",
          "default": "127.0.0.1",
          "placeholder": "127.0.0.1",
          "help": "OneBot 实现监听地址；反向连接场景可按 adapter 文档调整。"
        },
        {
          "name": "port",
          "label": "Port",
          "target": "bot",
          "type": "text",
          "default": "8080",
          "placeholder": "8080"
        },
        {
          "name": "access_token",
          "label": "Access token",
          "target": "bot",
          "type": "password",
          "placeholder": "optional_token",
          "help": "可选；如果 OneBot 实现设置了 token，这里必须一致。"
        }
      ]
    },
    {
      "id": "onebotv12",
      "label": "OneBot V12",
      "kind": "nonebot",
      "adapter": "onebot.v12",
      "env_key": "ONEBOTV12_BOTS",
      "emoji": "🤖",
      "help": "OneBot V12 的连接字段取决于具体实现。按 nonebot-adapter-onebot v12 文档填写。",
      "fields": [
        {"name": "host", "label": "Host", "target": "bot", "type": "text", "default": "127.0.0.1"},
        {"name": "port", "label": "Port", "target": "bot", "type": "text", "default": "8080"},
        {"name": "access_token", "label": "Access token", "target": "bot", "type": "password", "placeholder": "optional_token"},
        {"name": "impl", "label": "Implementation name", "target": "bot", "type": "text", "placeholder": "walleq"},
        {"name": "platform", "label": "Platform tag", "target": "bot", "type": "text", "placeholder": "qq"}
      ]
    },
    {
      "id": "discord",
      "label": "Discord",
      "kind": "nonebot",
      "adapter": "discord",
      "env_key": "DISCORD_BOTS",
      "emoji": "💬",
      "help": "Discord 需要在 Developer Portal 创建 bot，并开启需要的 Privileged Gateway Intents。",
      "fields": [
        {"name": "token", "label": "Bot token", "target": "bot", "type": "password", "required": true, "placeholder": "discord_bot_token"},
        {"name": "intents", "label": "Gateway intents", "target": "bot", "type": "text", "default": "536870912", "help": "按 Discord / adapter 文档填写；消息内容权限通常还要在 Developer Portal 开启。"}
      ]
    },
    {
      "id": "dingtalk",
      "label": "DingTalk",
      "kind": "nonebot",
      "adapter": "dingtalk",
      "env_key": "DINGTALK_BOTS",
      "emoji": "🔔",
      "help": "DingTalk 需要开放平台应用凭据。",
      "fields": [
        {"name": "client_id", "label": "Client ID / AppKey", "target": "bot", "type": "text", "required": true},
        {"name": "client_secret", "label": "Client secret / AppSecret", "target": "bot", "type": "password", "required": true}
      ]
    },
    {
      "id": "feishu",
      "label": "Feishu",
      "kind": "nonebot",
      "adapter": "feishu",
      "env_key": "FEISHU_BOTS",
      "emoji": "🪶",
      "help": "Feishu / Lark 需要开放平台应用凭据和事件订阅配置。",
      "fields": [
        {"name": "app_id", "label": "App ID", "target": "bot", "type": "text", "required": true, "placeholder": "cli_xxx"},
        {"name": "app_secret", "label": "App secret", "target": "bot", "type": "password", "required": true},
        {"name": "encrypt_key", "label": "Encrypt key", "target": "bot", "type": "password"},
        {"name": "verification_token", "label": "Verification token", "target": "bot", "type": "password"}
      ]
    },
    {
      "id": "kaiheila",
      "label": "Kaiheila / KOOK",
      "kind": "nonebot",
      "adapter": "kaiheila",
      "env_key": "KAIHEILA_BOTS",
      "emoji": "🪁",
      "help": "KOOK / Kaiheila 需要机器人 token。",
      "fields": [
        {"name": "token", "label": "Bot token", "target": "bot", "type": "password", "required": true},
        {"name": "name", "label": "Local bot label", "target": "bot", "type": "text", "default": "bot1"}
      ]
    },
    {
      "id": "mail",
      "label": "Mail",
      "kind": "nonebot",
      "adapter": "mail",
      "env_key": "MAIL_BOTS",
      "emoji": "📧",
      "help": "Mail channel 需要邮箱 SMTP/IMAP 连接信息。建议使用应用专用密码。",
      "fields": [
        {"name": "username", "label": "Email address", "target": "bot", "type": "text", "required": true},
        {"name": "password", "label": "App password", "target": "bot", "type": "password", "required": true},
        {"name": "imap_host", "label": "IMAP host", "target": "bot", "type": "text", "default": "imap.gmail.com"},
        {"name": "imap_port", "label": "IMAP port", "target": "bot", "type": "text", "default": "993"},
        {"name": "smtp_host", "label": "SMTP host", "target": "bot", "type": "text", "default": "smtp.gmail.com"},
        {"name": "smtp_port", "label": "SMTP port", "target": "bot", "type": "text", "default": "587"}
      ]
    },
    {
      "id": "minecraft",
      "label": "Minecraft",
      "kind": "nonebot",
      "adapter": "minecraft",
      "env_key": "MINECRAFT_BOTS",
      "emoji": "⛏",
      "help": "Minecraft channel 通常使用 RCON 或服务端插件接入。",
      "fields": [
        {"name": "host", "label": "Server host", "target": "bot", "type": "text", "required": true},
        {"name": "port", "label": "RCON port", "target": "bot", "type": "text", "default": "25575"},
        {"name": "password", "label": "RCON password", "target": "bot", "type": "password", "required": true}
      ]
    },
    {
      "id": "github",
      "label": "GitHub",
      "kind": "nonebot",
      "adapter": "github",
      "env_key": "GITHUB_BOTS",
      "emoji": "🐙",
      "help": "GitHub channel 通常需要 token 和 webhook secret。",
      "fields": [
        {"name": "token", "label": "GitHub token", "target": "bot", "type": "password", "required": true},
        {"name": "secret", "label": "Webhook secret", "target": "bot", "type": "password"}
      ]
    },
    {
      "id": "villa",
      "label": "Villa",
      "kind": "nonebot",
      "adapter": "villa",
      "env_key": "VILLA_BOTS",
      "emoji": "🏰",
      "help": "Villa 需要 bot_id、secret 等平台凭据。",
      "fields": [
        {"name": "bot_id", "label": "Bot ID", "target": "bot", "type": "text", "required": true},
        {"name": "secret", "label": "Bot secret", "target": "bot", "type": "password", "required": true}
      ]
    },
    {
      "id": "yunhu",
      "label": "Yunhu",
      "kind": "nonebot",
      "adapter": "yunhu",
      "env_key": "YUNHU_BOTS",
      "emoji": "☁",
      "help": "Yunhu 需要机器人 token。",
      "fields": [
        {"name": "token", "label": "Bot token", "target": "bot", "type": "password", "required": true}
      ]
    },
    {
      "id": "heybox",
      "label": "Heybox",
      "kind": "nonebot",
      "adapter": "heybox",
      "env_key": "HEYBOX_BOTS",
      "emoji": "📦",
      "help": "Heybox 需要机器人 token 或平台要求的授权字段。",
      "fields": [
        {"name": "token", "label": "Bot token", "target": "bot", "type": "password", "required": true}
      ]
    },
    {
      "id": "console",
      "label": "Console",
      "kind": "nonebot",
      "adapter": "console",
      "env_key": "CONSOLE_BOTS",
      "emoji": "🖥",
      "help": "Console adapter 主要用于本地调试，一般不需要真实平台 token。",
      "fields": [
        {"name": "name", "label": "Console label", "target": "bot", "type": "text", "default": "console"}
      ]
    },
    {
      "id": "weclaw",
      "label": "微信 / WeClaw",
      "kind": "weclaw",
      "adapter": "weclaw",
      "env_key": "",
      "emoji": "🟢",
      "help": "微信渠道使用 WeClaw，不走 NoneBot adapter，也不需要平台 token。扫码登录由 WeClaw 自己保存会话。",
      "fields": [
        {"name": "WECLAW_ENABLED", "label": "Enable WeClaw", "target": "env", "type": "boolean", "default": "true"},
        {"name": "WECLAW_USERNAME", "label": "Local WeClaw account name", "target": "env", "type": "text", "default": "default"},
        {"name": "WECLAW_BIN", "label": "WeClaw binary", "target": "env", "type": "text", "default": "weclaw"},
        {"name": "WECLAW_CONFIG", "label": "WeClaw config path", "target": "env", "type": "text", "default": "~/.weclaw/config.json"},
        {"name": "WECLAW_PROXY_HOST", "label": "Proxy host", "target": "env", "type": "text", "default": "127.0.0.1"},
        {"name": "WECLAW_PROXY_PORT", "label": "Proxy port", "target": "env", "type": "text", "default": "51298"},
        {"name": "WECLAW_AUTO_INSTALL", "label": "Auto-install on first run", "target": "env", "type": "boolean", "default": "true"}
      ]
    },
    {
      "id": "webhook",
      "label": "Custom Webhook",
      "kind": "webhook",
      "adapter": "webhook",
      "env_key": "",
      "emoji": "🔗",
      "help": "Webhook 使用本地通用 adapter。默认平台名是 webhook；自定义平台可手动添加 <NAME>_WEBHOOK_URL 并在白名单中使用小写 <name>。",
      "fields": [
        {"name": "WEBHOOK_WEBHOOK_URL", "label": "Webhook URL", "target": "env", "type": "text", "placeholder": "https://example.com/incoming-webhook"},
        {"name": "WEBHOOK_WEBHOOK_SECRET", "label": "Shared secret", "target": "env", "type": "password"},
        {"name": "WEBHOOK_REPLY_URL", "label": "Reply URL", "target": "env", "type": "text", "placeholder": "https://example.com/reply-endpoint"},
        {"name": "WEBHOOK_DEFAULT_ALLOW", "label": "Allow users not in whitelist", "target": "env", "type": "boolean", "default": "false"}
      ]
    }
  ]
}
