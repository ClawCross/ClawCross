#!/bin/bash
# ClawCross CLI launcher — model and provider management
#
# Usage:
#   ./scripts/clawcross model              # interactive model selection
#   ./scripts/clawcross model gpt-4o       # set LLM_MODEL directly
#   ./scripts/clawcross provider           # interactive provider selection
#   ./scripts/clawcross provider openai    # set LLM_PROVIDER with default base URL

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(dirname "$SCRIPT_DIR")"

exec python3 -m clawcross_cli.main "$@"
